<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required so `open -a` (an Apple Event) is allowed under hardened runtime. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <!-- uiohook-napi loads a native binding that allocates JIT/dynamic memory. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- uiohook-napi's native binding isn't co-signed with the app bundle. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
