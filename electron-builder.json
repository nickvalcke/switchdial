{
  "appId": "dev.workbench.switchdial",
  "productName": "switchdial",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": ["dist/**/*", "electron/**/*", "package.json"],
  "asarUnpack": ["node_modules/uiohook-napi/**/*"],
  "publish": null,
  "mac": {
    "category": "public.app-category.utilities",
    "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "identity": null,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "extendInfo": {
      "LSUIElement": true,
      "NSAppleEventsUsageDescription": "switchdial needs to launch the apps you've added to your dial.",
      "NSAccessibilityUsageDescription": "switchdial needs Accessibility access to detect your Control+click gesture anywhere on screen."
    }
  }
}
